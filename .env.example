# OpenClaw Gateway Security Token
# Required to access the admin UI securely
OPENCLAW_GATEWAY_TOKEN=your_secure_random_token_here

# AI Provider API Keys
# Provide the keys for the models you intend to use
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# (Optional) Other Provider Keys
# GEMINI_API_KEY=
# GROQ_API_KEY=

# OpenClaw Specific Configurations can be added here
# For example, default model settings, etc.
